# =============================================================================
# FastGPT 配置
# =============================================================================
FASTGPT_BASE_URL=https://your-domain.com/api
FASTGPT_API_KEY=your-api-key
FASTGPT_DATASET_ID=your-dataset-id

# 调度器（可选）
FASTGPT_ENABLE_SCHEDULER=true
FASTGPT_TIMEZONE=Asia/Shanghai
FASTGPT_DAILY_SYNC_TIME=02:00

# =============================================================================
# 本地文档扫描（可选，用于本地文件批量处理）
# =============================================================================
# 根目录（支持 JSON 数组或逗号分隔）
FASTGPT_LOCAL_DIR=["./input"]
# 中文文档子目录名
FASTGPT_CN_SUBDIR=cn
# 支持的文件扩展名
FASTGPT_FILE_EXTENSIONS=.pdf,.md,.txt,.json,.docx,.html
# 忽略的文件/目录（正则表达式）
FASTGPT_IGNORE_PATTERNS=^\..*,.*\.tmp$,__pycache__

# =============================================================================
# 文本分块
# =============================================================================
FASTGPT_CHUNK_SIZE=1500
FASTGPT_CHUNK_SPLIT_MODE=size

# =============================================================================
# 同步状态
# =============================================================================
FASTGPT_SYNC_STATE_DB=./data/fastgpt_sync_state.json

# =============================================================================
# 推送重试
# =============================================================================
FASTGPT_PUSH_RETRY_TIMES=3
FASTGPT_PUSH_RETRY_DELAY_SECONDS=5

# =============================================================================
# 输出目录（临时文件存储）
# =============================================================================
OUTPUT_DIR=./output

# =============================================================================
# 知识库质检 Agent（可选）
# =============================================================================
# API Key 读取顺序：QA_AGENT_API_KEY → DASHSCOPE_API_KEY（建议在 ~/.zshrc 中 export）
DASHSCOPE_API_KEY=your-dashscope-key
QA_AGENT_PROVIDER=qwen
QA_AGENT_MODEL=qwen3.7-max
QA_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QA_AGENT_RUBRIC=agents/rubrics/medical.yaml
QA_AGENT_SCORE_THRESHOLD=85
QA_AGENT_TIMEOUT=60

# =============================================================================
# Frontmatter 富化（可选，download-and-clean --enrich 时使用）
# =============================================================================
# 自动优先级 fallback（代码层面）：
#   1. qwen3.6-flash  ← DASHSCOPE_API_KEY 存在时（速度最快，适合翻译/标签化）
#   2. glm-4.5-air    ← ZHIPUAI_API_KEY 存在时（免费）
#   3. step-3.5-flash ← SILICONFLOW_API_KEY 存在时（低成本）
#   4. 回退到 QA_AGENT_* 配置
#
# 用户可通过 ENRICHER_* 显式覆盖自动选择。

# --- 厂商 API Key（用于自动 fallback）---
# ZHIPUAI_API_KEY=your-zhipuai-key          # 智谱（glm-4.5-air 免费）
# SILICONFLOW_API_KEY=your-siliconflow-key  # 硅基流动（step-3.5-flash 低成本）

# --- 显式覆盖配置（取消注释以强制使用指定模型）---
# ENRICHER_MODEL=qwen3.6-flash
# ENRICHER_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ENRICHER_API_KEY=your-dashscope-key
# ENRICHER_PROVIDER=qwen
# ENRICHER_TIMEOUT=60
